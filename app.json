{
  "expo": {
    "name": "Carnatic Metronome",
    "slug": "carnatic-metronome",
    "version": "0.3.0-beta",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": [
      "**/*"
    ],
    "description": "Beta-ready Carnatic tala metronome with editable templates and resilient playback.",
    "scheme": "carnaticmetronome",
    "owner": "REPLACE_WITH_EXPO_OWNER",
    "icon": "./assets/icons/app-icon.png",
    "splash": {
      "image": "./assets/splash/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#101418"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.carnaticmetronome",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.example.carnaticmetronome",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#101418"
      }
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
